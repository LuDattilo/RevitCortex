<Page x:Class="RevitCortex.Plugin.UI.UsageReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="550">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Usage Report" FontSize="22" FontWeight="SemiBold" Foreground="#333"/>
            <TextBlock Text="Token consumption and estimated costs from the Revit chat panel" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Period selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Period:" FontSize="13" VerticalAlignment="Center" Foreground="#333" Margin="0,0,8,0"/>
            <ComboBox x:Name="PeriodCombo" Width="120" Padding="6,4" FontSize="13" BorderBrush="#E0E0E0"
                      SelectionChanged="Period_Changed">
                <ComboBoxItem Content="Today" IsSelected="True"/>
                <ComboBoxItem Content="Last 7 days"/>
                <ComboBoxItem Content="Last 30 days"/>
                <ComboBoxItem Content="All time"/>
            </ComboBox>
            <Button Content="Refresh" Padding="12,4" Margin="10,0,0,0" FontSize="12"
                    Background="#F5F5F5" Foreground="#333" BorderBrush="#E0E0E0"
                    Click="Refresh_Click" Cursor="Hand"/>
        </StackPanel>

        <!-- Summary cards -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Calls -->
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="API Calls" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="TotalCallsText" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#333"/>
                </StackPanel>
            </Border>

            <!-- Total Tokens -->
            <Border Grid.Column="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12" Margin="5,0,5,0">
                <StackPanel>
                    <TextBlock Text="Total Tokens" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="TotalTokensText" Text="0" FontSize="22" FontWeight="SemiBold" Foreground="#333"/>
                </StackPanel>
            </Border>

            <!-- Estimated Cost -->
            <Border Grid.Column="2" Background="#E0F7FA" BorderBrush="#80DEEA" BorderThickness="1" CornerRadius="4" Padding="12" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Est. Cost" FontSize="11" Foreground="#006064"/>
                    <TextBlock x:Name="TotalCostText" Text="$0.00" FontSize="22" FontWeight="SemiBold" Foreground="#00838F"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Top tools table -->
        <Border Grid.Row="3" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table header -->
                <Border Grid.Row="0" Background="#F5F5F5" Padding="10,6" CornerRadius="4,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="Tool" FontSize="12" FontWeight="SemiBold" Foreground="#666"/>
                        <TextBlock Grid.Column="2" Text="Calls" FontSize="12" FontWeight="SemiBold" Foreground="#666" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="Tokens" FontSize="12" FontWeight="SemiBold" Foreground="#666" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="Cost" FontSize="12" FontWeight="SemiBold" Foreground="#666" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Table rows -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ToolsTable">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Rank}" FontSize="12" Foreground="#999"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ToolName}" FontSize="12" Foreground="#333"
                                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Calls}" FontSize="12" Foreground="#333" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Tokens}" FontSize="12" Foreground="#333" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Cost}" FontSize="12" Foreground="#00838F"
                                                   FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyText" Grid.Row="1" Text="No usage data for this period"
                           FontSize="13" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Export CSV" Padding="15,8" FontSize="13"
                    Background="#00838F" Foreground="White" BorderBrush="#006064"
                    Click="ExportCsv_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>
