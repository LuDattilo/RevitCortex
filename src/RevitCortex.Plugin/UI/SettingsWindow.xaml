<Window x:Class="RevitCortex.Plugin.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RevitCortex Settings" Height="500" Width="750"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,10,0,0">
                <Border Padding="12,6" Margin="0,0,0,4">
                    <TextBlock Text="RevitCortex" FontSize="15" FontWeight="SemiBold" Foreground="#00838F"/>
                </Border>
                <ListBox x:Name="NavListBox" BorderThickness="0" Background="Transparent"
                         SelectionChanged="NavListBox_SelectionChanged">
                    <ListBoxItem x:Name="GeneralItem" IsSelected="True" Padding="10,8">
                        <TextBlock Text="General" FontSize="14"/>
                    </ListBoxItem>
                    <ListBoxItem x:Name="ToolsItem" Padding="10,8">
                        <TextBlock Text="Tools" FontSize="14"/>
                    </ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Right content -->
        <Grid Grid.Column="1" Margin="15">
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
