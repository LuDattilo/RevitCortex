<Page x:Class="RevitCortex.Plugin.UI.CortexPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FAFAFA" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar — teal accent -->
        <Border Grid.Row="0" Background="#FAFAFA" Padding="14,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="4" Background="#00838F" Margin="0,0,8,0">
                        <TextBlock Text="RC" Foreground="White" FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="RevitCortex" Foreground="#212121" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="7" Height="7" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StatusText" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#DDD" FontSize="11"/>
                    <TextBlock Text="New chat" Foreground="#00838F" FontSize="11"
                               Cursor="Hand" MouseLeftButtonDown="ClearChat_Click"/>
                    <TextBlock Text="  |  " Foreground="#DDD" FontSize="11"/>
                    <TextBlock Text="Export" Foreground="#00838F" FontSize="11"
                               Cursor="Hand" MouseLeftButtonDown="ExportChat_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Messages -->
        <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Background="#FAFAFA">
            <ItemsControl x:Name="ChatMessages">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding RowBackground}" Padding="20,16"
                                BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Avatar -->
                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="4"
                                        Background="{Binding AvatarBackground}" Margin="0,2,14,0" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding AvatarLetter}" Foreground="White" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Content -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding RoleLabel}" Foreground="{Binding RoleLabelColor}"
                                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Text, Mode=OneWay}"
                                             Foreground="{Binding TextColor, Mode=OneWay}"
                                             FontSize="14" TextWrapping="Wrap"
                                             FontFamily="{Binding FontFamily, Mode=OneWay}"
                                             IsReadOnly="True" AcceptsReturn="True"
                                             BorderThickness="0" Background="Transparent"
                                             VerticalScrollBarVisibility="Disabled"
                                             HorizontalScrollBarVisibility="Disabled"
                                             IsTabStop="False" Padding="0" Margin="0"
                                             SelectionBrush="#00838F"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Typing indicator -->
        <Border Grid.Row="2" x:Name="TypingIndicator" Visibility="Collapsed"
                Background="#F5F5F5" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="4"
                        Background="#00838F" Margin="0,0,14,0">
                    <TextBlock Text="RC" Foreground="White" FontSize="9" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" x:Name="TypingText" Text="Thinking..."
                           Foreground="#999" FontSize="14" FontStyle="Italic" VerticalAlignment="Center"/>
                <Border Grid.Column="2" CornerRadius="10" Padding="8,3" Margin="8,0,0,0"
                        Background="#EEEEEE" BorderBrush="#BDBDBD" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonDown="StopButton_Click">
                    <TextBlock Text="Stop" FontSize="10" Foreground="#757575" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Prompt Chips -->
        <Border Grid.Row="3" x:Name="ChipsBar" Background="#F5F5F5" Padding="12,6"
                BorderBrush="#EEEEEE" BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="PromptChips">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="12" Background="#E0F7FA" Margin="0,0,6,4"
                                    Padding="10,5" Cursor="Hand"
                                    MouseLeftButtonDown="Chip_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#B2EBF2"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Text}" FontSize="12" Foreground="#006064"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Input area -->
        <Border Grid.Row="4" Background="#FAFAFA" Padding="16,10,16,16">
            <Border Background="White" CornerRadius="22"
                    BorderBrush="#BDBDBD" BorderThickness="1"
                    Padding="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBox x:Name="ChatInput"
                                 Background="Transparent" Foreground="#212121" CaretBrush="#212121"
                                 BorderThickness="0" Padding="16,14,50,14" FontSize="14"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MaxHeight="150" VerticalScrollBarVisibility="Auto"
                                 KeyDown="ChatInput_KeyDown"
                                 VerticalContentAlignment="Top"
                                 FontFamily="Segoe UI"/>
                        <TextBlock x:Name="Placeholder" Text="Reply... (Ctrl+Enter to send)" IsHitTestVisible="False"
                                   Foreground="#AAA" FontSize="14" Padding="18,14,0,0"
                                   FontFamily="Segoe UI"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="8,0,8,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" />

                        <Button x:Name="SendButton" Grid.Column="1" Click="Send_Click"
                                Background="Transparent" BorderThickness="0"
                                Padding="0" Cursor="Hand" VerticalAlignment="Center">
                            <Border Width="28" Height="28" CornerRadius="14" Background="#00838F">
                                <Path Data="M5,3L19,12L5,21Z" Fill="White"
                                      Width="9" Height="11" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" Margin="1,0,0,0"/>
                            </Border>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
