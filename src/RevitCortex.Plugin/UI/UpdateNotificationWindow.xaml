<Window x:Class="RevitCortex.Plugin.UI.UpdateNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RevitCortex — Aggiornamento"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        Loaded="Window_Loaded">

    <!-- Accent bar on top -->
    <Border BorderBrush="#FFB300" BorderThickness="0,3,0,0" Background="White">
        <StackPanel Margin="18,14,18,16">

            <!-- Header -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="NotifTitle"
                               Text="Aggiornamento disponibile"
                               FontSize="14" FontWeight="SemiBold" Foreground="#212121"/>
                    <TextBlock x:Name="NotifDetail"
                               FontSize="12" Foreground="#666"
                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" x:Name="VersionBadgeBorder"
                        Background="#FFB300" CornerRadius="4"
                        Padding="8,3" VerticalAlignment="Top" Margin="10,0,0,0">
                    <TextBlock x:Name="VersionBadge"
                               FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Download progress (hidden by default) -->
            <Grid x:Name="ProgressGrid" Visibility="Collapsed" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ProgressBar x:Name="ProgressBar" Grid.Row="0"
                             Height="5" Minimum="0" Maximum="100" Value="0"
                             Background="#E0E0E0" Foreground="#1976D2"/>
                <TextBlock x:Name="ProgressText" Grid.Row="1"
                           FontSize="10" Foreground="#888" Margin="0,3,0,0"/>
            </Grid>

            <!-- Confirm-install warning (hidden by default) -->
            <Border x:Name="ConfirmBorder" Visibility="Collapsed"
                    Background="#FFF8E1" BorderBrush="#FFB300" BorderThickness="1"
                    CornerRadius="4" Padding="10,8" Margin="0,0,0,12">
                <TextBlock FontSize="12" Foreground="#5D4037" TextWrapping="Wrap">
                    Revit verrà chiuso per completare l'installazione.
                    Salva il lavoro prima di continuare.
                </TextBlock>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <Button x:Name="SecondaryButton" Content="Più tardi"
                        Padding="14,7" Margin="0,0,8,0" FontSize="12"
                        Background="#F5F5F5" Foreground="#333" BorderBrush="#E0E0E0"
                        Click="Secondary_Click" Cursor="Hand"/>
                <Button x:Name="PrimaryButton" Content="Aggiorna ora"
                        Padding="14,7" FontSize="12" FontWeight="SemiBold"
                        Background="#FFB300" Foreground="White" BorderBrush="#FF8F00"
                        Click="Primary_Click" Cursor="Hand"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
