<Page x:Class="RevitCortex.Plugin.UI.ApiKeySettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="550">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="API Key" FontSize="22" FontWeight="SemiBold" Foreground="#333"/>
            <TextBlock Text="Configure the Anthropic API key for the built-in chat panel"
                       Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,20,0">
                <!-- Status -->
                <Border Background="#F5F5F5" CornerRadius="4" Padding="15,12" Margin="0,0,0,15"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Status: " FontSize="14" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusSourceText" FontSize="12" Foreground="#666"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </Border>

                <Separator Margin="0,0,0,15" Background="#E0E0E0"/>

                <!-- Key input -->
                <TextBlock Text="API Key" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Column="0"
                                 Padding="8,6" FontSize="14" BorderBrush="#E0E0E0"
                                 PasswordChanged="ApiKeyPasswordBox_PasswordChanged"/>
                    <TextBox x:Name="ApiKeyTextBox" Grid.Column="0"
                             Padding="8,6" FontSize="14" BorderBrush="#E0E0E0"
                             Visibility="Collapsed"
                             TextChanged="ApiKeyTextBox_TextChanged"/>
                    <Button x:Name="ToggleVisibilityButton" Grid.Column="1" Content="Show"
                            Padding="10,6" Margin="8,0,0,0" FontSize="12"
                            Background="#F5F5F5" Foreground="#333" BorderBrush="#E0E0E0"
                            Click="ToggleVisibility_Click" Cursor="Hand"/>
                </Grid>

                <Separator Margin="0,0,0,15" Background="#E0E0E0"/>

                <!-- Storage method -->
                <TextBlock Text="Storage Method" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                <RadioButton x:Name="EnvVarRadio" GroupName="Storage" Margin="0,0,0,8"
                             FontSize="13" Foreground="#333">
                    <TextBlock Text="Environment Variable (ANTHROPIC_API_KEY)"/>
                </RadioButton>
                <RadioButton x:Name="FileRadio" GroupName="Storage" Margin="0,0,0,15"
                             FontSize="13" Foreground="#333">
                    <TextBlock Text="File (%USERPROFILE%\.claude\api_key.txt)"/>
                </RadioButton>

                <!-- Info -->
                <Border Background="#E0F7FA" CornerRadius="4" Padding="12,10" Margin="0,0,0,10"
                        BorderBrush="#80DEEA" BorderThickness="1">
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#006064">
                        The API key is only needed for the built-in chat panel. Claude Desktop and Claude Code use their own authentication.
                    </TextBlock>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save API Key" Padding="20,8" FontSize="13"
                    Background="#00838F" Foreground="White" BorderBrush="#006064"
                    Click="Save_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>
