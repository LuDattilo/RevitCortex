<Page x:Class="RevitCortex.Plugin.UI.ToolsSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="550">
    <Page.Resources>
        <!-- Expander toggle style -->
        <Style x:Key="CategoryExpander" TargetType="Expander">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="IsExpanded" Value="False"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <ContentPresenter Content="{Binding}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Tools" FontSize="22" FontWeight="SemiBold" Foreground="#333"/>
            <TextBlock Text="Enable or disable individual tools" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Search + counters -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" Padding="8,6" FontSize="13"
                     BorderBrush="#E0E0E0" TextChanged="SearchBox_TextChanged">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Tag" Value=""/>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <TextBlock x:Name="SearchPlaceholder" Grid.Column="0" Text="Search tools..."
                       IsHitTestVisible="False" Foreground="#AAA" FontSize="13"
                       Padding="10,7,0,0" VerticalAlignment="Top"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <TextBlock x:Name="ToolCountText" FontSize="12" Foreground="#666" VerticalAlignment="Center"/>
                <TextBlock Text="  |  " Foreground="#DDD" FontSize="12"/>
                <TextBlock Text="All" Foreground="#00838F" FontSize="12" Cursor="Hand"
                           MouseLeftButtonDown="SelectAll_Click" Margin="0,0,6,0"/>
                <TextBlock Text="None" Foreground="#00838F" FontSize="12" Cursor="Hand"
                           MouseLeftButtonDown="DeselectAll_Click"/>
                <TextBlock Text="  |  " Foreground="#DDD" FontSize="12"/>
                <TextBlock Text="Expand" Foreground="#00838F" FontSize="12" Cursor="Hand"
                           MouseLeftButtonDown="ExpandAll_Click" Margin="0,0,6,0"/>
                <TextBlock Text="Collapse" Foreground="#00838F" FontSize="12" Cursor="Hand"
                           MouseLeftButtonDown="CollapseAll_Click"/>
            </StackPanel>
        </Grid>

        <!-- Tools list grouped by category with Expanders -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True">
                <ItemsControl x:Name="CategoryList"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Style="{StaticResource CategoryExpander}"
                                      IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                <Expander.Header>
                                    <Grid Background="#F5F5F5" Margin="-2,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                                   FontSize="13" FontWeight="SemiBold" Foreground="#00838F"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        <TextBlock Grid.Column="2" FontSize="11" Foreground="#999"
                                                   VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} / {1}">
                                                    <Binding Path="EnabledCount"/>
                                                    <Binding Path="TotalCount"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Tools}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,6" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Top" Margin="0,2,10,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding ToolName}" FontSize="13"
                                                                   Foreground="#333" FontFamily="Consolas"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                                   Foreground="#888" Margin="0,2,0,0"
                                                                   TextWrapping="Wrap" MaxWidth="400"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save" Padding="20,8" FontSize="13"
                    Background="#00838F" Foreground="White" BorderBrush="#006064"
                    Click="Save_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>
