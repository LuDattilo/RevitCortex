<Window x:Class="RevitCortex.Plugin.PowerBi.ProfilePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Carica profilo" Height="380" Width="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Seleziona un profilo salvato:" Margin="0,0,0,8"/>
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1">
            <ListView x:Name="ProfileList" BorderThickness="0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Nome" Width="180" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Categorie" Width="80" DisplayMemberBinding="{Binding Categories.Count}"/>
                        <GridViewColumn Header="Parametri" Width="80">
                            <GridViewColumn.DisplayMemberBinding>
                                <Binding Path="InstanceParameters.Count"/>
                            </GridViewColumn.DisplayMemberBinding>
                        </GridViewColumn>
                        <GridViewColumn Header="Ultima modifica" Width="140" DisplayMemberBinding="{Binding LastUsed, StringFormat='dd/MM/yyyy HH:mm'}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Elimina" Width="80" Margin="0,0,8,0" Click="Delete_Click"/>
            <Button Content="Annulla" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Carica" Width="80" IsDefault="True" Click="Load_Click"/>
        </StackPanel>
    </Grid>
</Window>
